// ═══════════════════════════════════════════════════════════════════════════════
// PRISMA SCHEMA ADDITIONS — Biometric Teacher Payroll System
// Add these models to your existing schema.prisma
//
// ⚠️  SchoolAttendanceConfig is NOT added here.
//     School timings (start time, end time, required hours) are derived
//     from the EXISTING TimetableConfig → PeriodDefinition models.
//     First PERIOD startTime = school start.
//     Last  PERIOD endTime   = school end.
//     No duplication of timing data.
// ═══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────────────
// 1. SCHOOL PAYROLL CONFIG  (grace periods only — timing comes from TimetableConfig)
// ─────────────────────────────────────────────────────────────────────────────
model SchoolPayrollConfig {
  id       String @id @default(cuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Grace periods (minutes)
  lateGraceMinutes      Int @default(15)
  earlyExitGraceMinutes Int @default(15)

  // Worked-time thresholds as fraction of gross school hours (from timetable)
  halfDayThresholdPct Float @default(0.5)
  absentThresholdPct  Float @default(0.25)

  // Leave quotas per year (0 = unlimited / not enforced)
  casualLeavePerYear Int @default(12)
  sickLeavePerYear   Int @default(6)
  earnedLeavePerYear Int @default(0)

  updatedAt     DateTime @updatedAt
  updatedById   String?
  updatedByName String?

  @@map("school_payroll_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. TEACHER DAILY ATTENDANCE
//    One record per teacher per calendar day — the finalized attendance record.
//    Salary is NEVER calculated from raw BiometricLog — always from this table.
// ─────────────────────────────────────────────────────────────────────────────
model TeacherDailyAttendance {
  id        String         @id @default(cuid())
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  date          DateTime // midnight IST of the calendar day (stored as UTC)
  firstPunch    DateTime? // MIN(punchDateTime) for the day
  lastPunch     DateTime? // MAX(punchDateTime) for the day
  workedMinutes Int? // (lastPunch - firstPunch) in minutes

  status                 PayrollAttendanceStatus
  isLate                 Boolean                 @default(false)
  lateMinutes            Int? // minutes past grace period
  isLateExcused          Boolean                 @default(false)
  isMissingPunchReviewed Boolean                 @default(false)

  // Manual correction tracking
  originalStatus PayrollAttendanceStatus? // status before first correction
  correctedAt    DateTime?
  correctedById  String?
  correctedBy    User?                    @relation("AttendanceCorrectedBy", fields: [correctedById], references: [id])

  // Leave fields (set when admin marks ON_LEAVE)
  leaveType       String? // CASUAL | SICK | EARNED | OTHER
  leaveReason     String? // admin notes
  isLeaveDeducted Boolean @default(true) // true = cut salary, false = paid leave (no deduction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AttendanceAuditLog[]

  @@unique([teacherId, date])
  @@index([schoolId, date])
  @@index([teacherId, date])
  @@index([schoolId, status])
  @@map("teacher_daily_attendance")
}

// Separate enum name to avoid clash with existing AttendanceStatus / TeacherAttendanceStatus
enum PayrollAttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  MISSING_PUNCH
  HOLIDAY
  PENDING
  ON_LEAVE
}

// ─────────────────────────────────────────────────────────────────────────────
// 3. ATTENDANCE AUDIT LOG — immutable, append-only
// ─────────────────────────────────────────────────────────────────────────────
model AttendanceAuditLog {
  id           String                 @id @default(cuid())
  attendanceId String
  attendance   TeacherDailyAttendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  action             AttendanceAuditAction
  previousStatus     PayrollAttendanceStatus?
  newStatus          PayrollAttendanceStatus?
  previousFirstPunch DateTime?
  newFirstPunch      DateTime?
  previousLastPunch  DateTime?
  newLastPunch       DateTime?
  reason             String?
  performedById      String?
  performedByName    String?
  performedBy        User?                    @relation("AuditPerformedBy", fields: [performedById], references: [id])
  performedAt        DateTime                 @default(now())

  @@index([attendanceId])
  @@map("attendance_audit_logs")
}

enum AttendanceAuditAction {
  APPROVE_PRESENT
  MARK_LATE
  MARK_HALF_DAY
  MARK_ABSENT
  EXCUSE_LATE
  UPDATE_IN_TIME
  UPDATE_OUT_TIME
  UPDATE_STATUS
  SYSTEM_CALCULATED
  MISSING_PUNCH_REVIEWED
  MARK_ON_LEAVE
  MARK_SCHOOL_HOLIDAY
}

// ─────────────────────────────────────────────────────────────────────────────
// 4. TEACHER MONTHLY PAYROLL
//    Generated from TeacherDailyAttendance — never from BiometricLog directly.
//    Locked payrolls cannot be regenerated.
// ─────────────────────────────────────────────────────────────────────────────
model TeacherMonthlyPayroll {
  id        String         @id @default(cuid())
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  month Int // 1–12
  year  Int

  // Calendar breakdown
  totalDays    Int
  sundayCount  Int
  holidayCount Int
  workingDays  Int // totalDays - sundays - holidays

  // Attendance summary (copied from TeacherDailyAttendance at generation time)
  presentDays      Int @default(0)
  lateDays         Int @default(0)
  halfDays         Int @default(0)
  absentDays       Int @default(0)
  holidayDays      Int @default(0)
  missingPunchDays Int @default(0)
  paidLeaveDays    Int @default(0) // ON_LEAVE where isLeaveDeducted = false
  unpaidLeaveDays  Int @default(0) // ON_LEAVE where isLeaveDeducted = true

  // Salary
  monthlySalary    Decimal @db.Decimal(12, 2)
  dailySalary      Decimal @db.Decimal(12, 2)
  absentDeduction  Decimal @default(0) @db.Decimal(12, 2)
  halfDayDeduction Decimal @default(0) @db.Decimal(12, 2)
  lateDeduction    Decimal @default(0) @db.Decimal(12, 2)
  leaveDeduction   Decimal @default(0) @db.Decimal(12, 2) // unpaid leave deduction
  totalDeduction   Decimal @default(0) @db.Decimal(12, 2)
  netSalary        Decimal @db.Decimal(12, 2)

  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?
  lockedBy   User?     @relation("PayrollLockedBy", fields: [lockedById], references: [id])

  generatedAt   DateTime @default(now())
  generatedById String?
  generatedBy   User?    @relation("PayrollGeneratedBy", fields: [generatedById], references: [id])
  updatedAt     DateTime @updatedAt

  @@unique([teacherId, month, year])
  @@index([schoolId, month, year])
  @@map("teacher_monthly_payrolls")
}

model BiometricStudentAttendance {
  id String @id @default(cuid())

  // ── Core relations ──────────────────────────────────────────────────────────
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  // ── Date (IST midnight stored as UTC) ──────────────────────────────────────
  // e.g. 2026-06-16 00:00:00 IST = 2026-06-15 18:30:00 UTC
  date DateTime

  // ── Punch times (PunchMode from device is IGNORED — timestamps only) ───────
  firstPunch DateTime? // MIN(punchDateTime) for the day — entry time, set once
  lastPunch  DateTime? // MAX(punchDateTime) for the day — exit time, updated on each punch

  // ── Status ─────────────────────────────────────────────────────────────────
  // Uses same PayrollAttendanceStatus enum (already exists in schema)
  // PRESENT       = worked >= school hours
  // LATE          = present but arrived after grace period
  // HALF_DAY      = worked >= 50% of school hours
  // MISSING_PUNCH = only 1 punch recorded (no exit), or very short stay
  // (ABSENT rows are NOT created — absent = no row for that student on that date)
  status BiometricStudentStatus @default(MISSING_PUNCH)

  isLate      Boolean @default(false)
  lateMinutes Int? // minutes past grace period

  // ── Audit ───────────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Constraints ─────────────────────────────────────────────────────────────
  @@unique([studentId, date]) // one row per student per day
  @@index([schoolId, date]) // query all students for a school on a date
  @@index([classSectionId, date]) // query by class on a date (most common UI query)
  @@index([studentId, date]) // query one student's history
  @@index([schoolId, status]) // filter by status
  @@index([academicYearId, date]) // year-wise reports
  @@map("biometric_student_attendance")
}

// Separate enum for student biometric attendance status
// (avoids clash with existing AttendanceStatus and PayrollAttendanceStatus)
enum BiometricStudentStatus {
  PRESENT
  LATE
  HALF_DAY
  MISSING_PUNCH // 1 punch only — no exit recorded
  HOLIDAY // school holiday — can be set by admin
}

// ─────────────────────────────────────────────────────────────────────────────
// 1. SCHOOL VEHICLE — admin registers vehicle once with regNo
//    regNo is the join key between our DB and GPS API response
// ─────────────────────────────────────────────────────────────────────────────
model SchoolVehicle {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  regNo       String // "KA50EL0766" — must match what GPS API returns
  vehicleName String? // "School Bus 1", "Van 2" — friendly name for UI
  vehicleType String? // "BUS", "VAN", "SCOOTY", "AUTO" etc — from GPS API or manual

  // GPS hardware device ID — comes from API response, stored for reference
  deviceId String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations VehicleLocation[]

  @@unique([schoolId, regNo]) // same regNo cannot be added twice to same school
  @@index([schoolId])
  @@index([regNo]) // fast lookup when matching API response
  @@map("school_vehicles")
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. VEHICLE LOCATION — stores every GPS API response
//    One row per API poll per vehicle
//    Use latest row for current location, all rows for history
// ─────────────────────────────────────────────────────────────────────────────
model VehicleLocation {
  id String @id @default(cuid())

  schoolVehicleId String
  schoolVehicle   SchoolVehicle @relation(fields: [schoolVehicleId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  regNo String // stored directly for easy querying without join

  // ── Location data (from GPS API) ──────────────────────────────────────────
  latitude  Float?
  longitude Float?
  speed     Float? // km/h
  bearing   Float? // direction in degrees

  // ── Status ────────────────────────────────────────────────────────────────
  status         String? // "PARKED", "MOVING", "IDLE", "OFF"
  ignitionStatus String? // "ON", "OFF"
  vehicleStatus  String? // "PARKED", "MOVING"

  // ── Address (reverse geocoded by GPS provider) ────────────────────────────
  address String?

  // ── Extra data from API ───────────────────────────────────────────────────
  odoDistance  Float? // total odometer distance in km
  fuelLitre    Float? // fuel level if available
  batteryLevel Float?

  // ── Timestamps ────────────────────────────────────────────────────────────
  gpsTimestamp DateTime? // "isoDate" from API — when GPS recorded this position
  recordedAt   DateTime  @default(now()) // when we stored it in our DB

  // ── Raw API response (store everything for future use) ────────────────────
  rawData Json?

  @@index([schoolVehicleId, recordedAt]) // latest location per vehicle
  @@index([schoolId, recordedAt]) // all vehicles for a school
  @@index([regNo, recordedAt]) // lookup by regNo
  @@index([recordedAt]) // time-based queries
  @@map("vehicle_locations")
}

enum VehicleStatusType {
  PARKED
  MOVING
  IDLE
  OFF
}

enum VoiceTargetType {
  SCHOOL
  CLASS
  STUDENT
}

model VoiceAnnouncement {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title       String?
  description String?

  audioUrl String
  audioKey String

  durationSec Int?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  createdBySuperAdminId String?
  createdBySuperAdmin   SuperAdmin? @relation(fields: [createdBySuperAdminId], references: [id], onDelete: Cascade)

  publishAt DateTime
  expireAt  DateTime

  totalRecipients Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targets VoiceAnnouncementTarget[]
  listens VoiceAnnouncementListen[]

  @@index([schoolId])
  @@index([publishAt])
  @@index([expireAt])
  @@map("voice_announcements")
}

model VoiceAnnouncementTarget {
  id String @id @default(uuid())

  announcementId String
  announcement   VoiceAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  targetType VoiceTargetType

  classSectionId String?
  classSection   ClassSection? @relation(fields: [classSectionId], references: [id])

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())

  @@index([classSectionId])
  @@index([studentId])
  @@index([announcementId])
  @@map("voice_announcement_targets")
}

model VoiceAnnouncementListen {
  id String @id @default(uuid())

  announcementId String
  announcement   VoiceAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  listenCount Int @default(0)

  firstListenedAt DateTime?
  lastListenedAt  DateTime?

  createdAt DateTime @default(now())

  @@unique([announcementId, parentId])
  @@index([parentId])
  @@map("voice_announcement_listens")
}

model IdCardOrder {
