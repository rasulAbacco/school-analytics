generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  FINANCE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SlotDayType {
  WEEKDAY
  SATURDAY
}

enum StudentStatus {
  ACTIVE
  COMPLETED
  INACTIVE
  GRADUATED
  SUSPENDED
  PENDING_READMISSION
  FAILED
}

enum BloodGroup {
  A_POS  @map("A+")
  A_NEG  @map("A-")
  B_POS  @map("B+")
  B_NEG  @map("B-")
  O_POS  @map("O+")
  O_NEG  @map("O-")
  AB_POS @map("AB+")
  AB_NEG @map("AB-")
}

enum DocumentType {
  AADHAR_CARD
  BIRTH_CERTIFICATE
  PASSBOOK
  TRANSFER_CERTIFICATE
  MARKSHEET
  MIGRATION_CERTIFICATE
  CHARACTER_CERTIFICATE
  MEDICAL_CERTIFICATE
  PASSPORT
  CASTE_CERTIFICATE
  INCOME_CERTIFICATE
  PHOTO
  CUSTOM
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
}

enum TeacherDocumentType {
  ID_PROOF
  ADDRESS_PROOF
  DEGREE_CERTIFICATE
  EXPERIENCE_CERTIFICATE
  CONTRACT_DOCUMENT
  PAN_CARD
  AADHAR_CARD
  PHOTO
  CUSTOM
}

enum SchoolType {
  SCHOOL
  PUC
  DIPLOMA
  DEGREE
  POSTGRADUATE
  OTHER
}

enum SlotType {
  PERIOD
  SHORT_BREAK
  LUNCH_BREAK
  PRAYER
  OTHER
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ExtraClassDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ExtraClassType {
  HOLIDAY
  WEEKEND
  BEFORE_HOURS
  AFTER_HOURS
  OTHER
}

enum MeetingType {
  TEACHING_STAFF
  NON_TEACHING_STAFF
  PARENTS
  STUDENTS
  GENERAL
  BOARD
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  POSTPONED
}

enum MeetingParticipantType {
  USER
  PARENT
  EXTERNAL
  STAFF
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  EXCUSED
}

enum TeacherAttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum CourseType {
  STREAM
  DEGREE_COURSE
}

enum PromotionAction {
  PROMOTED
  GRADUATED
  SKIPPED
  READMITTED
}

enum CasteCategory {
  SC
  ST
  OBC
  GM
  OTHER
}

enum SchoolBoard {
  KSEEB // Karnataka State Board
  CBSE
  ICSE
  NIOS // National Institute of Open Schooling
  IB // International Baccalaureate
  IGCSE
  STATE // Other state boards
  OTHER
}

model University {
  id            String    @id @default(uuid())
  name          String
  code          String    @unique
  address       String?
  city          String?
  state         String?
  phone         String?
  email         String?
  website       String?
  logoUrl       String?
  isActive      Boolean   @default(true)
  isDeactivated Boolean   @default(false)
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  superAdmins  SuperAdmin[]
  schools      School[]
  Payment      Payment[]
  Subscription Subscription[]

  @@index([code])
  @@map("universities")
}

model SuperAdmin {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  phone        String?
  profileImage String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  schoolAccess SuperAdminSchoolAccess[]

  Payment Payment[]
  schools School[]

  voiceAnnouncements VoiceAnnouncement[]

  @@index([universityId])
  @@map("super_admins")
}

model SuperAdminSchoolAccess {
  id           String     @id @default(uuid())
  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([superAdminId, schoolId])
  @@map("super_admin_school_access")
}

model School {
  id            String     @id @default(uuid())
  name          String
  code          String     @unique
  deletedAt     DateTime?
  type          SchoolType
  address       String?
  city          String?
  state         String?
  phone         String?
  email         String?
  logoUrl       String?
  isActive      Boolean    @default(true)
  isDeactivated Boolean    @default(false)
  deactivatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  superAdminId String?

  superAdmin            SuperAdmin?              @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  superAdminAccess      SuperAdminSchoolAccess[]
  users                 User[]                   @relation("SchoolUsers")
  students              Student[]
  parents               Parent[]
  teachers              TeacherProfile[]
  academicYears         AcademicYear[]
  classSections         ClassSection[]
  subjects              Subject[]
  timetableConfigs      TimetableConfig[]
  assessmentTerms       AssessmentTerm[]
  assessmentGroups      AssessmentGroup[]
  FinanceProfile        FinanceProfile[]
  TeacherMonthlySalary  TeacherMonthlySalary[]
  Stream                Stream[]
  Course                Course[]
  SchoolPromotionConfig SchoolPromotionConfig?
  PromotionLog          PromotionLog[]
  ExtraClass            ExtraClass[]
  Meeting               Meeting[]
  TeacherAttendance     TeacherAttendance[]
  TimetableEntry        TimetableEntry[]
  subjectSyllabus       SubjectSyllabus[]
  portionProgress       SectionPortionProgress[]
  galleryAlbums         GalleryAlbum[]
  holidays              SchoolHoliday[]
  activities            Activity[]
  activityEvents        ActivityEvent[]
  Award                 Award[]
  liveClasses           LiveClass[]
  StaffProfile          StaffProfile[]
  assignments           Assignment[]
  transportRoutes       TransportRoute[]
  transportStops        TransportStop[]
  StudentTransport      StudentTransport[]
  ClassFee              ClassFee[]
  TransportFeePlan      TransportFeePlan[]
  Subscription          Subscription[]

  StudentFinance         StudentFinance[]
  StudentList            StudentList[]
  GroupDStaffSalary      GroupDStaffSalary[]
  Payment                Payment[]
  TeacherTutorialProfile TeacherTutorialProfile[]
  adminProfiles          SchoolAdminProfile[]
  AdminMonthlySalary     AdminMonthlySalary[]
  Expense                Expense[]
  reEvaluationSettings   ReEvaluationSetting[]
  reEvaluationRequests   ReEvaluationRequest[]
  biometricDevices       BiometricDevice[]
  biometricUserMappings  BiometricUserMapping[]
  biometricLogs          BiometricLog[]

  payrollConfig      SchoolPayrollConfig?
  teacherAttendances TeacherDailyAttendance[]
  teacherPayrolls    TeacherMonthlyPayroll[]
  schoolVehicles     SchoolVehicle[]
  vehicleLocations   VehicleLocation[]
  voiceAnnouncements VoiceAnnouncement[]
  idCardOrders       IdCardOrder[]
  idCardTemplates    IdCardTemplate[]

  biometricStudentAttendances BiometricStudentAttendance[]

  @@index([universityId])
  @@index([type])
  @@index([code])
  @@index([superAdminId])
  @@map("schools")
}

model Stream {
  id              String   @id @default(uuid())
  name            String
  code            String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  hasCombinations Boolean  @default(false)
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classSections ClassSection[]
  combinations  StreamCombination[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("streams")
}

model Course {
  id             String     @id @default(uuid())
  name           String
  code           String?
  type           CourseType @default(DEGREE_COURSE)
  totalSemesters Int
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  schoolId      String
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  hasBranches   Boolean        @default(false)
  branches      CourseBranch[]
  classSections ClassSection[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("courses")
}

model CourseBranch {
  id        String   @id @default(uuid())
  name      String
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  classSections ClassSection[]

  @@unique([name, courseId])
  @@index([courseId])
  @@map("course_branches")
}

model SchoolPromotionConfig {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  skipGrades String[]
  lastGrade  String?
  firstGrade String?

  @@map("school_promotion_configs")
}

model PromotionLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  fromAcademicYearId String
  toAcademicYearId   String

  totalPromoted  Int @default(0)
  totalGraduated Int @default(0)
  totalSkipped   Int @default(0)
  totalFailed    Int @default(0)
  totalInactive  Int @default(0)

  triggeredById String
  notes         String?

  @@index([schoolId])
  @@map("promotion_logs")
}

model StudentReadmission {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  previousAdmissionNumber String
  previousGrade           String
  previousAcademicYearId  String
  previousClassSectionId  String

  newAdmissionNumber String
  newGrade           String
  newAcademicYearId  String
  newClassSectionId  String

  reason          String?
  readmissionDate DateTime @default(now())

  @@index([studentId])
  @@map("student_readmissions")
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
}

model Parent {
  id              String    @id @default(uuid())
  name            String
  deletedAt       DateTime?
  email           String
  password        String
  phone           String?
  anniversaryDate DateTime?
  occupation      String?
  profileImage    String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentLinks          StudentParent[]
  meetingParticipations MeetingParticipant[]
  reEvaluationRequests  ReEvaluationRequest[]

  voiceAnnouncementListens VoiceAnnouncementListen[]

  @@unique([email, schoolId])
  @@index([schoolId])
  @@map("parents")
}

model StudentParent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  relation         ParentRelation
  isPrimary        Boolean        @default(false)
  emergencyContact Boolean        @default(false)

  @@unique([studentId, parentId])
  @@unique([studentId, relation])
  @@index([studentId])
  @@index([parentId])
  @@map("student_parents")
}

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String
  role        StaffRole
  deletedAt   DateTime?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  planId      String?
  maxSchools  Int       @default(1)
  schoolId    String?
  school      School?   @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: Cascade)

  organizedMeetings        Meeting[]            @relation("MeetingOrganizer")
  teacherProfile           TeacherProfile?
  meetingParticipations    MeetingParticipant[]
  markedAttendances        AttendanceRecord[]   @relation("AttendanceMarkedBy")
  markedTeacherAttendances TeacherAttendance[]  @relation("TeacherAttendanceMarkedBy")
  financeProfile           FinanceProfile?
  galleryAlbumsCreated     GalleryAlbum[]       @relation("UserGalleryAlbums")
  SchoolHoliday            SchoolHoliday[]
  createdActivities        Activity[]
  createdEvents            ActivityEvent[]
  createdTeams             EventTeam[]
  recordedResults          EventResult[]
  StudentAward             StudentAward[]
  StaffProfile             StaffProfile?
  Certificate              Certificate[]
  classFeeCreated          ClassFee[]           @relation("ClassFeeCreatedBy")
  classFeeUpdated          ClassFee[]           @relation("ClassFeeUpdatedBy")

  schoolAdminProfile   SchoolAdminProfile?
  AdminMonthlySalary   AdminMonthlySalary[]
  FinanceMonthlySalary FinanceMonthlySalary[]
  reEvaluationRequests ReEvaluationRequest[]

  biometricLogs         BiometricLog[]
  biometricUserMappings BiometricUserMapping[]
  voiceAnnouncements    VoiceAnnouncement[]

  attendancesCorrected TeacherDailyAttendance[] @relation("AttendanceCorrectedBy")
  auditLogsPerformed   AttendanceAuditLog[]     @relation("AuditPerformedBy")
  payrollsLocked       TeacherMonthlyPayroll[]  @relation("PayrollLockedBy")
  payrollsGenerated    TeacherMonthlyPayroll[]  @relation("PayrollGeneratedBy")

  biometricAssignedMappings BiometricUserMapping[] @relation("BiometricAssignedBy")

  @@unique([email, schoolId])
  @@index([role])
  @@index([isActive])
  @@index([schoolId])
  @@map("users")
}

model SchoolAdminProfile {
  id String @id @default(cuid())

  userId   String  @unique
  schoolId String?

  // ADMIN DETAILS
  adminName   String?
  email       String?
  phoneNumber String?
  address     String?

  employeeId  String?
  designation String?

  // SALARY
  basicSalary Float @default(0)

  // BANK DETAILS
  bankName      String?
  accountNumber String?
  ifscCode      String?

  // DOCUMENT DETAILS
  panNumber    String?
  aadharNumber String?

  photoUrl          String?
  panDocumentUrl    String?
  aadharDocumentUrl String?

  // OTHER DETAILS
  joiningDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Student {
  id          String  @id @default(uuid())
  studentCode String? @unique @db.VarChar(10)

  name      String
  email     String
  password  String
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  personalInfo    StudentPersonalInfo?
  documents       StudentDocumentInfo[]
  enrollments     StudentEnrollment[]
  marks           Marks[]
  resultSummaries ResultSummary[]

  parentLinks                   StudentParent[]
  meetings                      MeetingStudent[]
  attendanceRecords             AttendanceRecord[]
  readmissions                  StudentReadmission[]
  activityEnrollments           StudentActivityEnrollment[]
  eventParticipants             EventParticipant[]
  teamMemberships               EventTeamMember[]
  eventResults                  EventResult[]
  certificates                  Certificate[]
  StudentAward                  StudentAward[]
  liveClassAttendance           LiveClassAttendance[]
  transportAssignments          StudentTransport[]
  devices                       Device[]
  assignmentSubmissions         AssignmentSubmission[]
  StudentTutorialRecommendation StudentTutorialRecommendation[]
  assignmentDrafts              AssignmentDraft[]
  reEvaluationRequests          ReEvaluationRequest[]
  biometricUserMappings         BiometricUserMapping[]
  biometricLogs                 BiometricLog[]
  biometricAttendances          BiometricStudentAttendance[]
  voiceAnnouncementTargets      VoiceAnnouncementTarget[]

  @@index([email, schoolId])
  @@index([schoolId])
  @@index([studentCode])
  @@index([schoolId, isActive, createdAt])
  @@map("students")
}

model StudentPersonalInfo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  gender       Gender?
  profileImage String?

  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  aadhaarNumber String?        @db.VarChar(12)
  panNumber     String?        @db.VarChar(10)
  satsNumber    String?
  nationality   String?        @default("Indian")
  religion      String?
  casteCategory CasteCategory?

  motherTongue         String? // Kannada, Telugu, Tamil, Hindi, English, Urdu, Other
  subcaste             String? // Sub-caste (needed for SC/ST/OBC certificates)
  domicileState        String? @default("Karnataka")
  annualIncome         Float? // Family annual income (needed for fee waivers)
  physicallyChallenged Boolean @default(false)
  disabilityType       String? // e.g. Visual, Hearing, Locomotor, etc.

  parentName       String?
  parentEmail      String?
  parentPhone      String?
  emergencyContact String?

  bloodGroup        BloodGroup?
  medicalConditions String?
  allergies         String?

  heightCm         Float?
  weightKg         Float?
  identifyingMarks String? // Birthmarks, scars, etc.

  @@map("student_personal_info")
}

model StudentEnrollment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admissionNumber String
  admissionDate   DateTime

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  rollNumber String?
  externalId String?
  status     StudentStatus @default(ACTIVE)

  previousSchoolName  String? // Name of school/college student came from
  previousSchoolBoard SchoolBoard? // KSEEB, CBSE, ICSE, etc.
  udiseCode           String? // Karnataka: UDISE code of previous school
  lateralEntry        Boolean      @default(false) // Diploma/Degree lateral entry

  @@unique([studentId, academicYearId])
  @@unique([admissionNumber, academicYearId])
  @@unique([classSectionId, academicYearId, rollNumber])
  @@index([classSectionId])
  @@index([academicYearId])
  @@index([academicYearId, status])
  @@map("student_enrollments")
}

model StudentDocumentInfo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  documentName DocumentType
  customLabel  String?

  fileKey       String
  fileUrl       String?
  fileType      String
  fileSizeBytes Int?

  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  uploadedAt DateTime  @default(now())
  deletedAt  DateTime?

  @@index([studentId])
  @@map("student_document_info")
}

model Subject {
  id          String  @id @default(uuid())
  name        String
  code        String?
  description String?
  isElective  Boolean @default(false)
  gradeLevel  String?

  schoolId                      String
  school                        School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deletedAt                     DateTime?
  classSubjects                 ClassSubject[]
  assessmentSchedules           AssessmentSchedule[]
  TeacherAssignment             TeacherAssignment[]
  extraClasses                  ExtraClass[]
  timetableEntries              TimetableEntry[]
  subjectSyllabus               SubjectSyllabus[]
  portionProgress               SectionPortionProgress[]
  liveClasses                   LiveClass[]
  assignments                   Assignment[]
  StudentTutorialRecommendation StudentTutorialRecommendation[]
  reEvaluationSettings          ReEvaluationSetting[]
  reEvaluationRequests          ReEvaluationRequest[]

  @@unique([code, schoolId])
  @@index([schoolId])
  @@index([gradeLevel])
  @@map("subjects")
}

model ClassSubject {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  deletedAt      DateTime?
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([classSectionId, subjectId, academicYearId])
  @@index([classSectionId])
  @@index([academicYearId])
  @@map("class_subjects")
}

model TeacherProfile {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  schoolId        String
  school          School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?
  employeeCode    String         @unique
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  gender          Gender?
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  profileImage    String?
  department      String
  designation     String
  qualification   String?
  experienceYears Int?
  joiningDate     DateTime
  employmentType  EmploymentType
  status          TeacherStatus  @default(ACTIVE)
  salary          Decimal?       @db.Decimal(10, 2)
  bankAccountNo   String?
  bankName        String?
  ifscCode        String?
  panNumber       String?
  aadhaarNumber   String?

  bloodGroup        BloodGroup? // reuses existing BloodGroup enum
  emergencyContact  String? // single emergency phone number
  medicalConditions String? // free-text e.g. "Diabetes, Hypertension"
  allergies         String? // free-text e.g. "Penicillin, Peanuts"

  assignments            TeacherAssignment[]
  documents              TeacherDocument[]
  classTeacherOf         ClassSectionAcademicYear[]
  extraClasses           ExtraClass[]
  teacherAttendances     TeacherAttendance[]
  TeacherMonthlySalary   TeacherMonthlySalary[]
  GroupBStaffSalary      GroupBStaffSalary[]
  timetableEntries       TimetableEntry[]           @relation("TeacherTimetableEntries")
  syllabusCreated        SubjectSyllabus[]          @relation("SyllabusCreatedBy")
  syllabusUpdated        SubjectSyllabus[]          @relation("SyllabusUpdatedBy")
  portionProgress        SectionPortionProgress[]
  liveClasses            LiveClass[]
  homeworkAssignments    Assignment[]
  TeacherTutorialProfile TeacherTutorialProfile[]
  biometricUserMappings  BiometricUserMapping[]
  biometricLogs          BiometricLog[]
  dailyAttendances       TeacherDailyAttendance[]
  monthlyPayrolls        TeacherMonthlyPayroll[]

  @@index([schoolId])
  @@index([department])
  @@index([status])
  @@index([schoolId, createdAt])
  @@map("teacher_profiles")
}

model TeacherAssignment {
  id        String         @id @default(uuid())
  createdAt DateTime       @default(now())
  deletedAt DateTime?
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([classSectionId, subjectId, academicYearId])
  @@index([teacherId])
  @@index([academicYearId])
  @@map("teacher_assignments")
}

model TeacherDocument {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  documentType  TeacherDocumentType
  customLabel   String?
  fileKey       String
  fileUrl       String?
  fileType      String
  fileSizeBytes Int?
  isVerified    Boolean             @default(false)
  verifiedAt    DateTime?

  @@index([teacherId])
  @@index([documentType])
  @@map("teacher_documents")
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
