  isDefault   Boolean @default(false)

  templateType String  @default("UPLOADED")
  templateKey  String?
  primaryColor String?
  accentColor  String?

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

