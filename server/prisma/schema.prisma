  schoolId   String
  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolName String

  templateId String?
  template   IdCardTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  classDetails Json @default("[]")
  totalCards   Int  @default(0)

  contactName  String?
  contactPhone String?
  contactEmail String?

  status IdCardOrderStatus @default(PENDING)
  notes  String?

  orderedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([orderedAt])
  @@map("id_card_orders")
}

enum IdCardOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
